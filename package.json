{
  "name": "@flowsell/connect",
  "version": "0.1.0",
  "description": "Official JavaScript and TypeScript SDK for FlowSell Connect wrapper APIs.",
  "type": "module",
  "license": "MIT",
  "author": "FlowSell",
  "homepage": "https://connect.flowsell.app/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-devesta/flowsell-connect-js-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/the-devesta/flowsell-connect-js-sdk/issues"
  },
  "keywords": [
    "flowsell",
    "connect",
    "whatsapp",
    "meta",
    "sdk",
    "api"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
